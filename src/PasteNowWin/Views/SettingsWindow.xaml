<Window x:Class="PasteNowWin.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PasteNowWin 设置"
        Width="440" Height="700"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="#F4F4F6">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,20">
        <TextBlock Text="PasteNowWin" FontSize="22" FontWeight="Bold" Foreground="#222" />
        <TextBlock x:Name="VersionText" Foreground="#777" Margin="0,2,0,18" />

        <CheckBox x:Name="StartupCheck" Content="开机自启动" Click="StartupCheck_Click"
                  FontSize="13" Margin="0,4" />
        <CheckBox x:Name="SoundCheck" Content="复制时播放提示音" Click="SoundCheck_Click"
                  FontSize="13" Margin="0,4" />

        <TextBlock x:Name="CountText" Foreground="#444" Margin="0,14,0,6" FontSize="13" />

        <StackPanel Orientation="Horizontal" Margin="0,4">
            <Button Content="清空历史(保留置顶)" Click="ClearKeepPinned_Click"
                    Padding="10,5" Margin="0,0,10,0" />
            <Button Content="全部清空" Click="ClearAll_Click" Padding="10,5" />
        </StackPanel>

        <TextBlock Text="最多保留(非置顶记录)" Foreground="#444" Margin="0,12,0,4" FontSize="13" />
        <ComboBox x:Name="MaxItemsCombo" Width="180" HorizontalAlignment="Left"
                  SelectionChanged="MaxItemsCombo_SelectionChanged">
            <ComboBoxItem Tag="200" Content="200 条" />
            <ComboBoxItem Tag="500" Content="500 条" />
            <ComboBoxItem Tag="1000" Content="1000 条" />
            <ComboBoxItem Tag="5000" Content="5000 条" />
        </ComboBox>

        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
            <Button Content="管理常用片段…" Click="ManageSnippets_Click" Padding="10,5" Margin="0,0,10,0" />
            <Button Content="管理列表…" Click="ManageLists_Click" Padding="10,5" />
        </StackPanel>

        <TextBlock Text="历史过期时间" FontWeight="Bold" Foreground="#222" FontSize="14" Margin="0,16,0,4" />
        <ComboBox x:Name="ExpiryCombo" Width="180" HorizontalAlignment="Left"
                  SelectionChanged="ExpiryCombo_SelectionChanged">
            <ComboBoxItem Tag="0" Content="永不过期" />
            <ComboBoxItem Tag="1" Content="1 天" />
            <ComboBoxItem Tag="7" Content="7 天" />
            <ComboBoxItem Tag="30" Content="30 天" />
            <ComboBoxItem Tag="90" Content="90 天" />
        </ComboBox>
        <TextBlock Text="超过该时间的非置顶记录会被自动清理(每小时检查一次)"
                   Foreground="#888" FontSize="11" Margin="0,4,0,0" />

        <TextBlock Text="排除规则" FontWeight="Bold" Foreground="#222" FontSize="14" Margin="0,16,0,4" />
        <TextBlock Text="每行一个进程名(如 KeePass、1Password),来自这些程序的复制不会被记录"
                   Foreground="#888" FontSize="11" Margin="0,0,0,4" TextWrapping="Wrap" />
        <TextBox x:Name="ExclusionsBox" Height="72" AcceptsReturn="True" TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto" FontSize="12"
                 TextChanged="ExclusionsBox_TextChanged" />

        <TextBlock Text="外观" FontWeight="Bold" Foreground="#222" FontSize="14" Margin="0,16,0,4" />
        <StackPanel Orientation="Horizontal">
            <StackPanel Margin="0,0,18,0">
                <TextBlock Text="主题" Foreground="#444" FontSize="12" Margin="0,0,0,3" />
                <ComboBox x:Name="ThemeCombo" Width="120" SelectionChanged="ThemeCombo_SelectionChanged">
                    <ComboBoxItem Tag="system" Content="跟随系统" />
                    <ComboBoxItem Tag="light" Content="浅色" />
                    <ComboBoxItem Tag="dark" Content="深色" />
                </ComboBox>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="弹窗大小" Foreground="#444" FontSize="12" Margin="0,0,0,3" />
                <ComboBox x:Name="PopupSizeCombo" Width="120" SelectionChanged="PopupSizeCombo_SelectionChanged">
                    <ComboBoxItem Tag="small" Content="小" />
                    <ComboBoxItem Tag="medium" Content="中" />
                    <ComboBoxItem Tag="large" Content="大" />
                </ComboBox>
            </StackPanel>
        </StackPanel>
        <TextBlock Text="主题仅影响历史弹窗" Foreground="#888" FontSize="11" Margin="0,4,0,0" />

        <TextBlock Text="密码保护" FontWeight="Bold" Foreground="#222" FontSize="14" Margin="0,16,0,4" />
        <TextBlock Text="设置主密码后,可在弹窗「密码」标签里加密保存密码;查看 / 粘贴需输入主密码。"
                   Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6" />
        <StackPanel Orientation="Horizontal">
            <Button x:Name="MasterPwButton" Click="MasterPw_Click" Padding="10,5" Margin="0,0,10,0" />
            <Button Content="管理密码…" Click="ManagePasswords_Click" Padding="10,5" />
        </StackPanel>

        <Separator Margin="0,18" />

        <TextBlock Text="快捷键" FontWeight="Bold" Foreground="#222" FontSize="14" />
        <TextBlock Text="点击按钮后按下新的组合键(需含修饰键),Esc 取消"
                   Foreground="#888" FontSize="11" Margin="0,0,0,6" />
        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="打开剪贴板历史" Foreground="#444"
                       VerticalAlignment="Center" Margin="0,4" />
            <Button Grid.Row="0" Grid.Column="1" x:Name="PopupHotkeyButton" Click="PopupHotkeyButton_Click"
                    Padding="10,4" Margin="0,4" HorizontalAlignment="Left" MinWidth="160" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="纯文本粘贴最近一条" Foreground="#444"
                       VerticalAlignment="Center" Margin="0,4" />
            <Button Grid.Row="1" Grid.Column="1" x:Name="PlainHotkeyButton" Click="PlainHotkeyButton_Click"
                    Padding="10,4" Margin="0,4" HorizontalAlignment="Left" MinWidth="160" />
        </Grid>
    </StackPanel>
    </ScrollViewer>
</Window>
