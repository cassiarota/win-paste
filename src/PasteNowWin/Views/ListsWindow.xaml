<Window x:Class="PasteNowWin.Views.ListsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理列表" Width="380" Height="360"
        WindowStartupLocation="CenterScreen" Background="#F4F4F6">
    <DockPanel Margin="14">
        <TextBlock DockPanel.Dock="Top" Text="自定义列表" FontWeight="Bold" Foreground="#222" Margin="0,0,0,6" />
        <TextBlock DockPanel.Dock="Top" Text="在历史弹窗右键条目即可「移到列表」;列表里的条目不会被自动清理。"
                   Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="新建" Click="New_Click" Width="76" Padding="0,5" Margin="0,0,8,0" />
            <Button Content="重命名" Click="Rename_Click" Width="76" Padding="0,5" Margin="0,0,8,0" />
            <Button Content="删除" Click="Delete_Click" Width="76" Padding="0,5" />
        </StackPanel>
        <ListBox x:Name="List" DisplayMemberPath="Name" />
    </DockPanel>
</Window>
