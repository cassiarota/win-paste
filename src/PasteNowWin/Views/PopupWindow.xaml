<Window x:Class="PasteNowWin.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PasteNowWin"
        Width="440" Height="560"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        WindowStartupLocation="Manual"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <ContextMenu x:Key="ItemMenu" Opened="ItemMenu_Opened" Closed="ItemMenu_Closed">
            <MenuItem Header="粘贴" Click="MenuPaste_Click" />
            <MenuItem Header="以纯文本粘贴" Click="MenuPastePlain_Click" />
            <Separator />
            <MenuItem Header="置顶 / 取消置顶" Click="MenuPin_Click" />
            <MenuItem Header="删除" Click="MenuDelete_Click" />
        </ContextMenu>
    </Window.Resources>

    <Border CornerRadius="14" Background="#F4F4F6" BorderBrush="#22000000" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.28" Color="#000000" />
        </Border.Effect>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search box -->
            <Border Grid.Row="0" CornerRadius="9" Background="White" Padding="10,7" Margin="2,2,2,8">
                <Grid>
                    <TextBlock x:Name="SearchPlaceholder" Text="搜索剪贴板历史…"
                               Foreground="#9A9A9A" VerticalAlignment="Center" IsHitTestVisible="False" />
                    <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                             VerticalAlignment="Center" FontSize="13"
                             TextChanged="SearchBox_TextChanged" />
                </Grid>
            </Border>

            <!-- History list -->
            <ListBox x:Name="ItemsList" Grid.Row="1"
                     BorderThickness="0" Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     HorizontalContentAlignment="Stretch"
                     MouseDoubleClick="ItemsList_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="ContextMenu" Value="{StaticResource ItemMenu}" />
                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="ListBoxItem_RightDown" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" CornerRadius="9" Background="White" Padding="10,8">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#DCEBFF" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#EAF2FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="8"
                                    Background="#F56A36" Margin="0,0,10,0" ClipToBounds="True">
                                <Grid>
                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                    <TextBlock Text="{Binding Glyph}" Visibility="{Binding GlyphVisibility}"
                                               Foreground="White" FontSize="15" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <TextBlock Grid.Column="1" Text="{Binding PreviewText}"
                                       TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="38"
                                       VerticalAlignment="Center" Foreground="#222222" FontSize="13" />

                            <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="8,1,0,0">
                                <TextBlock Text="📌" FontSize="10" Visibility="{Binding PinVisibility}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding TimeText}" Foreground="#9A9A9A" FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="2" Foreground="#9A9A9A" FontSize="11" Margin="4,8,4,2"
                       TextWrapping="Wrap"
                       Text="↑↓ 选择 · Enter 粘贴 · Ctrl+Enter 纯文本 · 右键更多操作 · Esc 关闭" />
        </Grid>
    </Border>
</Window>
