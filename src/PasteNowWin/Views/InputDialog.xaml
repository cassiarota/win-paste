<Window x:Class="PasteNowWin.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入" Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize" Background="#F4F4F6">
    <StackPanel Margin="18">
        <TextBlock x:Name="PromptText" TextWrapping="Wrap" Foreground="#333" Margin="0,0,0,8" />
        <TextBox x:Name="Box" Padding="6,4" FontSize="13" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="取消" IsCancel="True" Width="80" Padding="0,5" />
            <Button Content="确定" IsDefault="True" Click="Ok_Click" Width="80" Padding="0,5" Margin="8,0,0,0" />
        </StackPanel>
    </StackPanel>
</Window>
