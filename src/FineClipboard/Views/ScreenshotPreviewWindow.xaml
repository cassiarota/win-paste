<Window x:Class="FineClipboard.Views.ScreenshotPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="截图编辑" Width="940" Height="700" MinWidth="680" MinHeight="480"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource PopupBackground}"
        ResizeMode="CanResize" TextOptions.TextFormattingMode="Display" UseLayoutRounding="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="4,2,4,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="截图编辑" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center" Margin="0,0,16,0" />
                <ToggleButton x:Name="SelectTool" Content="选择" Tag="select" Checked="Tool_Checked" Margin="0,0,5,0"/>
                <ToggleButton x:Name="RectTool" Content="画框" Tag="rect" Checked="Tool_Checked" Margin="0,0,5,0"/>
                <ToggleButton x:Name="ArrowTool" Content="箭头" Tag="arrow" Checked="Tool_Checked" Margin="0,0,5,0"/>
                <ToggleButton x:Name="PenTool" Content="画笔" Tag="pen" Checked="Tool_Checked" Margin="0,0,5,0"/>
                <ToggleButton x:Name="MosaicTool" Content="马赛克" Tag="mosaic" Checked="Tool_Checked" Margin="0,0,5,0"/>
                <ToggleButton x:Name="TextTool" Content="文字" Tag="text" Checked="Tool_Checked" Margin="0,0,5,0"/>
                <Button Content="撤销" Click="Undo_Click"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="复制" Click="Copy_Click" Margin="0,0,6,0" />
                <Button Content="导出…" Click="Save_Click" Margin="0,0,6,0" />
                <Button Content="完成" Click="Done_Click" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="#B0000000" BorderBrush="{DynamicResource GlassBorderSubtleBrush}"
                BorderThickness="1" ClipToBounds="True">
            <Viewbox Stretch="Uniform">
                <Grid x:Name="EditorSurface" MouseLeftButtonDown="Editor_MouseLeftButtonDown"
                      MouseMove="Editor_MouseMove" MouseLeftButtonUp="Editor_MouseLeftButtonUp">
                    <Image x:Name="PreviewImage" Stretch="Fill" />
                    <Canvas x:Name="AnnotationCanvas" Background="#01FFFFFF" ClipToBounds="True" />
                </Grid>
            </Viewbox>
        </Border>

        <TextBlock Grid.Row="2" x:Name="Hint" Margin="4,9,4,1" Foreground="{DynamicResource TextSecondary}"
                   Text="选择工具后在图片上拖动；文字工具单击后输入。所有标注都会写入导出的图片。" />
    </Grid>
</Window>
