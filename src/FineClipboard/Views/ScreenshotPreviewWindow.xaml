<Window x:Class="FineClipboard.Views.ScreenshotPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="截图预览"
        Width="760" Height="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource PopupBackground}"
        ResizeMode="CanResize"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Border Margin="12" CornerRadius="22" Background="{DynamicResource GlassPanelBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="34" ShadowDepth="0" Opacity="0.28" Color="#00142A" />
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="截图预览" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="默认形状" Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Button Content="矩形" Margin="0,0,6,0" />
                        <Button Content="箭头" Margin="0,0,6,0" />
                        <Button Content="画笔" Margin="0,0,6,0" />
                        <Button Content="马赛克" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="另存为..." Click="Save_Click" Margin="0,0,8,0" />
                    <Button Content="关闭" Click="Close_Click" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" CornerRadius="16" Background="#66000000"
                    BorderBrush="{DynamicResource GlassBorderSubtleBrush}" BorderThickness="1"
                    ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Image x:Name="PreviewImage" Stretch="Uniform" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
