<Window x:Class="FineClipboard.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FineClipboard 设置"
        Width="640" Height="600"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource PopupBackground}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource Muted}">
            <Setter Property="Margin" Value="0,8,0,4" />
        </Style>
        <Style x:Key="HotkeyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,6" />
        </Style>
        <Style x:Key="HotkeyButton" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="Margin" Value="0,6" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource PopupBackground}"
            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="0">
        <Grid Margin="22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image x:Name="AppIconImage" Width="42" Height="42" Margin="0,0,12,0" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="FineClipboard" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" />
                    <TextBlock x:Name="VersionText" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0" />
                </StackPanel>
            </Grid>

            <TabControl Grid.Row="1">
                <TabItem Header="通用">
                    <Border Style="{StaticResource GlassSection}" Margin="10">
                        <StackPanel>
                            <CheckBox x:Name="StartupCheck" Content="开机自启动" Click="StartupCheck_Click" />
                            <CheckBox x:Name="SoundCheck" Content="复制时播放提示音" Click="SoundCheck_Click" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </TabItem>

                <TabItem Header="历史与隐私">
                    <Border Style="{StaticResource GlassSection}" Margin="10">
                        <StackPanel>
                            <CheckBox x:Name="PauseCheck" Content="暂停记录(隐私模式)" Click="PauseCheck_Click" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="最多保留(非收藏记录)" Style="{StaticResource FieldLabel}" />
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="MaxItemsCombo" Width="170"
                                          HorizontalAlignment="Left" SelectionChanged="MaxItemsCombo_SelectionChanged">
                                    <ComboBoxItem Tag="200" Content="200 条" />
                                    <ComboBoxItem Tag="500" Content="500 条" />
                                    <ComboBoxItem Tag="1000" Content="1000 条" />
                                    <ComboBoxItem Tag="5000" Content="5000 条" />
                                </ComboBox>
                                <TextBlock Grid.Row="1" Text="历史过期时间" Style="{StaticResource FieldLabel}" />
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ExpiryCombo" Width="170"
                                          HorizontalAlignment="Left" SelectionChanged="ExpiryCombo_SelectionChanged">
                                    <ComboBoxItem Tag="0" Content="永不过期" />
                                    <ComboBoxItem Tag="1" Content="1 天" />
                                    <ComboBoxItem Tag="7" Content="7 天" />
                                    <ComboBoxItem Tag="30" Content="30 天" />
                                    <ComboBoxItem Tag="90" Content="90 天" />
                                </ComboBox>
                            </Grid>
                            <TextBlock Text="超过该时间的非收藏记录会被自动清理。" Style="{StaticResource Muted}" Margin="210,4,0,0" />
                            <TextBlock Text="排除规则" Style="{StaticResource FieldLabel}" Margin="0,14,0,4" />
                            <TextBlock Text="每行一个进程名(如 KeePass、1Password)，来自这些程序的复制不会被记录。"
                                       Style="{StaticResource Muted}" Margin="0,0,0,6" />
                            <TextBox x:Name="ExclusionsBox" Height="120" AcceptsReturn="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" FontSize="12"
                                     TextChanged="ExclusionsBox_TextChanged" />
                            <TextBlock x:Name="CountText" Foreground="{DynamicResource TextSecondary}" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </TabItem>

                <TabItem Header="外观">
                    <Border Style="{StaticResource GlassSection}" Margin="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,18,0">
                                <TextBlock Text="主题" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <ComboBox x:Name="ThemeCombo" Width="170" HorizontalAlignment="Left"
                                          SelectionChanged="ThemeCombo_SelectionChanged">
                                    <ComboBoxItem Tag="system" Content="跟随系统" />
                                    <ComboBoxItem Tag="light" Content="浅色" />
                                    <ComboBoxItem Tag="dark" Content="深色" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="弹窗大小" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <ComboBox x:Name="PopupSizeCombo" Width="170" HorizontalAlignment="Left"
                                          SelectionChanged="PopupSizeCombo_SelectionChanged">
                                    <ComboBoxItem Tag="small" Content="小" />
                                    <ComboBoxItem Tag="medium" Content="中" />
                                    <ComboBoxItem Tag="large" Content="大" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem Header="快捷键">
                    <Border Style="{StaticResource GlassSection}" Margin="10">
                        <StackPanel>
                            <TextBlock Text="点击按钮后按下新的组合键(需含修饰键)，Esc 取消。" Style="{StaticResource Muted}" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="打开剪贴板历史" Style="{StaticResource HotkeyLabel}" />
                                <Button Grid.Row="0" Grid.Column="1" x:Name="PopupHotkeyButton"
                                        Click="PopupHotkeyButton_Click" Style="{StaticResource HotkeyButton}" />
                                <TextBlock Grid.Row="1" Text="纯文本粘贴最近一条" Style="{StaticResource HotkeyLabel}" />
                                <Button Grid.Row="1" Grid.Column="1" x:Name="PlainHotkeyButton"
                                        Click="PlainHotkeyButton_Click" Style="{StaticResource HotkeyButton}" />
                                <TextBlock Grid.Row="2" Text="截图" Style="{StaticResource HotkeyLabel}" />
                                <Button Grid.Row="2" Grid.Column="1" x:Name="ShotHotkeyButton"
                                        Click="ShotHotkeyButton_Click" Style="{StaticResource HotkeyButton}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </TabItem>

                <TabItem Header="同步">
                    <Border Style="{StaticResource GlassSection}" Margin="10">
                        <StackPanel>
                            <TextBlock Text="云同步使用同步口令端到端加密；密码数据不会参与同步。" Style="{StaticResource Muted}" />
                            <Button Content="打开云同步设置…" Click="OpenSync_Click" HorizontalAlignment="Left" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>
                </TabItem>

                <TabItem Header="密码">
                    <Border Style="{StaticResource GlassSection}" Margin="10">
                        <StackPanel>
                            <TextBlock Text="设置主密码后即可使用加密密码库。" Style="{StaticResource Muted}" />
                            <Button x:Name="MasterPwButton" Content="设置密码" Click="MasterPw_Click"
                                    HorizontalAlignment="Left" Margin="0,12,0,0" />
                            <TextBlock x:Name="PasswordConfiguredText" Text="密码已设置"
                                       Foreground="{DynamicResource TextPrimary}" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
