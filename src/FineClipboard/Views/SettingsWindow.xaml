<Window x:Class="FineClipboard.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FineClipboard 设置"
        Width="560" Height="760"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource PopupBackground}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource Muted}">
            <Setter Property="Margin" Value="0,8,0,4" />
        </Style>
    </Window.Resources>

    <Border Margin="14" CornerRadius="22" Background="{DynamicResource GlassPanelBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.22" Color="#00142A" />
        </Border.Effect>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22,20">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image x:Name="AppIconImage" Width="44" Height="44" Margin="0,0,12,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="FineClipboard" FontSize="24" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock x:Name="VersionText" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>

                <Border Style="{StaticResource GlassSection}">
                    <StackPanel>
                        <TextBlock Text="通用" Style="{StaticResource SectionTitle}" />
                        <CheckBox x:Name="StartupCheck" Content="开机自启动" Click="StartupCheck_Click" />
                        <CheckBox x:Name="SoundCheck" Content="复制时播放提示音" Click="SoundCheck_Click" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassSection}">
                    <StackPanel>
                        <TextBlock Text="历史与隐私" Style="{StaticResource SectionTitle}" />
                        <CheckBox x:Name="PauseCheck" Content="暂停记录(隐私模式)" Click="PauseCheck_Click" />

                        <TextBlock Text="最多保留(非置顶记录)" Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="MaxItemsCombo" Width="170" HorizontalAlignment="Left"
                                  SelectionChanged="MaxItemsCombo_SelectionChanged">
                            <ComboBoxItem Tag="200" Content="200 条" />
                            <ComboBoxItem Tag="500" Content="500 条" />
                            <ComboBoxItem Tag="1000" Content="1000 条" />
                            <ComboBoxItem Tag="5000" Content="5000 条" />
                        </ComboBox>

                        <TextBlock Text="历史过期时间" Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="ExpiryCombo" Width="170" HorizontalAlignment="Left"
                                  SelectionChanged="ExpiryCombo_SelectionChanged">
                            <ComboBoxItem Tag="0" Content="永不过期" />
                            <ComboBoxItem Tag="1" Content="1 天" />
                            <ComboBoxItem Tag="7" Content="7 天" />
                            <ComboBoxItem Tag="30" Content="30 天" />
                            <ComboBoxItem Tag="90" Content="90 天" />
                        </ComboBox>
                        <TextBlock Text="超过该时间的非置顶记录会被自动清理。" Style="{StaticResource Muted}" Margin="0,5,0,0" />

                        <TextBlock Text="排除规则" Style="{StaticResource FieldLabel}" />
                        <TextBlock Text="每行一个进程名(如 KeePass、1Password),来自这些程序的复制不会被记录。"
                                   Style="{StaticResource Muted}" Margin="0,0,0,6" />
                        <TextBox x:Name="ExclusionsBox" Height="78" AcceptsReturn="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto" FontSize="12"
                                 TextChanged="ExclusionsBox_TextChanged" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassSection}">
                    <StackPanel>
                        <TextBlock Text="外观" Style="{StaticResource SectionTitle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Text="主题" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <ComboBox x:Name="ThemeCombo" Width="150" HorizontalAlignment="Left"
                                          SelectionChanged="ThemeCombo_SelectionChanged">
                                    <ComboBoxItem Tag="system" Content="跟随系统" />
                                    <ComboBoxItem Tag="light" Content="浅色" />
                                    <ComboBoxItem Tag="dark" Content="深色" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="弹窗大小" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <ComboBox x:Name="PopupSizeCombo" Width="150" HorizontalAlignment="Left"
                                          SelectionChanged="PopupSizeCombo_SelectionChanged">
                                    <ComboBoxItem Tag="small" Content="小" />
                                    <ComboBoxItem Tag="medium" Content="中" />
                                    <ComboBoxItem Tag="large" Content="大" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassSection}">
                    <StackPanel>
                        <TextBlock Text="快捷键" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="点击按钮后按下新的组合键(需含修饰键),Esc 取消。" Style="{StaticResource Muted}" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="打开剪贴板历史" Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" Margin="0,5" />
                            <Button Grid.Row="0" Grid.Column="1" x:Name="PopupHotkeyButton" Click="PopupHotkeyButton_Click"
                                    Margin="0,5" HorizontalAlignment="Left" MinWidth="170" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="纯文本粘贴最近一条" Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" Margin="0,5" />
                            <Button Grid.Row="1" Grid.Column="1" x:Name="PlainHotkeyButton" Click="PlainHotkeyButton_Click"
                                    Margin="0,5" HorizontalAlignment="Left" MinWidth="170" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="截图" Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" Margin="0,5" />
                            <Border Grid.Row="2" Grid.Column="1" CornerRadius="10" Padding="12,6"
                                    HorizontalAlignment="Left" MinWidth="170"
                                    Background="{DynamicResource SurfaceBackground}" BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" Margin="0,5">
                                <TextBlock x:Name="ShotHotkeyText" Foreground="{DynamicResource TextPrimary}" />
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassSection}">
                    <StackPanel>
                        <TextBlock Text="同步" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="云同步使用同步口令端到端加密；密码数据不会参与同步。" Style="{StaticResource Muted}" />
                        <Button Content="打开云同步设置…" Click="OpenSync_Click" HorizontalAlignment="Left" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassSection}">
                    <StackPanel>
                        <TextBlock Text="密码" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="主密码用于加密本机密码库；锁定后查看 / 粘贴密码需重新输入。" Style="{StaticResource Muted}" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="MasterPwButton" Click="MasterPw_Click" Margin="0,0,10,0" />
                            <Button Content="管理密码…" Click="ManagePasswords_Click" Margin="0,0,10,0" />
                            <Button Content="锁定密码" Click="LockPasswords_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassSection}">
                    <StackPanel>
                        <TextBlock Text="维护" Style="{StaticResource SectionTitle}" />
                        <TextBlock x:Name="CountText" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="管理常用片段…" Click="ManageSnippets_Click" Margin="0,0,10,0" />
                            <Button Content="管理列表…" Click="ManageLists_Click" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="清空历史(保留置顶)" Click="ClearKeepPinned_Click" Margin="0,0,10,0" />
                            <Button Content="全部清空" Click="ClearAll_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
