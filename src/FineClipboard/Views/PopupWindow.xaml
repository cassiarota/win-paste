<Window x:Class="FineClipboard.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FineClipboard"
        Width="440" Height="560"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        WindowStartupLocation="Manual"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <ContextMenu x:Key="ItemMenu" Opened="ItemMenu_Opened" Closed="ItemMenu_Closed">
            <MenuItem Header="粘贴" Click="MenuPaste_Click" />
            <MenuItem Tag="pasteplain" Header="以纯文本粘贴" Click="MenuPastePlain_Click" />
            <MenuItem Tag="edit" Header="编辑后粘贴…" Click="MenuEdit_Click" />
            <MenuItem Tag="transform" Header="转换后粘贴">
                <MenuItem Header="去除首尾空格" Click="MenuTrimSpace_Click" />
                <MenuItem Header="合并为单行" Click="MenuSingleLine_Click" />
                <MenuItem Header="转为大写" Click="MenuUpper_Click" />
                <MenuItem Header="转为小写" Click="MenuLower_Click" />
            </MenuItem>
            <Separator />
            <MenuItem Tag="movelist" Header="移到列表" />
            <MenuItem Tag="copy" Header="复制(放回剪贴板)" Click="MenuCopy_Click" />
            <MenuItem Tag="openurl" Header="用浏览器打开链接" Click="MenuOpenUrl_Click" />
            <MenuItem Tag="locate" Header="在资源管理器中定位" Click="MenuLocate_Click" />
            <MenuItem Tag="saveimage" Header="图片另存为…" Click="MenuSaveImage_Click" />
            <Separator />
            <MenuItem Tag="pin" Header="置顶 / 取消置顶" Click="MenuPin_Click" />
            <MenuItem Tag="delete" Header="删除" Click="MenuDelete_Click" />
        </ContextMenu>
    </Window.Resources>

    <Border CornerRadius="20" Background="{DynamicResource PopupBackground}"
            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.24" Color="#00142A" />
        </Border.Effect>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search box -->
            <Border Grid.Row="0" CornerRadius="13" Background="{DynamicResource SurfaceBackground}" Padding="12,8" Margin="2,2,2,10"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <TextBlock x:Name="SearchPlaceholder" Text="搜索剪贴板历史…"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" IsHitTestVisible="False" />
                    <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                             Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}"
                             VerticalAlignment="Center" FontSize="13"
                             TextChanged="SearchBox_TextChanged" />
                </Grid>
            </Border>

            <!-- Type filter tabs -->
            <ListBox x:Name="FilterTabs" Grid.Row="1" Margin="2,0,2,8"
                     BorderThickness="0" Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                     SelectionChanged="FilterTabs_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,6,0" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="pill" CornerRadius="12" Padding="12,5" Background="#00000000">
                                        <ContentPresenter HorizontalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="pill" Property="Background" Value="{DynamicResource SurfaceHover}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="pill" Property="Background" Value="{DynamicResource AccentBrush}" />
                                            <Setter Property="TextElement.Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBoxItem>全部</ListBoxItem>
                <ListBoxItem>文本</ListBoxItem>
                <ListBoxItem>图片</ListBoxItem>
                <ListBoxItem>文件</ListBoxItem>
                <ListBoxItem>置顶</ListBoxItem>
                <ListBoxItem>片段</ListBoxItem>
                <ListBoxItem>密码</ListBoxItem>
            </ListBox>

            <!-- History list + empty hint -->
            <Grid Grid.Row="2">
                <ListBox x:Name="ItemsList"
                         BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch"
                         MouseDoubleClick="ItemsList_MouseDoubleClick"
                         PreviewMouseLeftButtonDown="ItemsList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="ItemsList_PreviewMouseMove">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="ContextMenu" Value="{StaticResource ItemMenu}" />
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="ListBoxItem_RightDown" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" CornerRadius="13" Background="{DynamicResource SurfaceBackground}" Padding="10,8"
                                                BorderBrush="{DynamicResource GlassBorderSubtleBrush}" BorderThickness="1">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceSelected}" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceHover}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="18" Height="18" CornerRadius="5"
                                        Background="{DynamicResource AccentBrush}" Margin="0,0,8,0"
                                        VerticalAlignment="Center" Visibility="{Binding BadgeVisibility}">
                                    <TextBlock Text="{Binding Badge}" Foreground="White" FontSize="11"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10"
                                        Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" ClipToBounds="True">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                        <TextBlock Text="{Binding Glyph}" Visibility="{Binding GlyphVisibility}"
                                                   Foreground="White" FontSize="15" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <TextBlock Grid.Column="2" Text="{Binding PreviewText}"
                                           TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="38"
                                           VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontSize="13" />

                                <StackPanel Grid.Column="3" VerticalAlignment="Top" Margin="8,1,0,0">
                                    <TextBlock Text="📌" FontSize="10" Visibility="{Binding PinVisibility}"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding TimeText}" Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11" Visibility="{Binding TimeVisibility}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="EmptyHint" Text="还没有历史记录,复制点东西试试"
                           Foreground="{DynamicResource TextSecondary}" FontSize="13" TextWrapping="Wrap"
                           TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="20" Visibility="Collapsed" IsHitTestVisible="False" />
            </Grid>

            <TextBlock Grid.Row="3" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="4,8,4,2"
                       TextWrapping="Wrap"
                       Text="1–9 快速粘贴 · ↑↓ 选择 · Enter 粘贴 · Ctrl+Enter 纯文本 · 右键更多 · Esc 关闭" />
        </Grid>
    </Border>
</Window>
